---
import '../styles/main.scss';
import DesktopSidebar from '../components/layout/desktop-sidebar/DesktopSidebar.astro';
import type { SidebarTocItem } from '../config/navigation';
import { socialLinks } from '../config/navigation';
import { siteRoutes } from '../config/site';

interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
  sidebarToc?: SidebarTocItem[];
}

const {
  title,
  description = '',
  bodyClass = '',
  sidebarToc = [],
} = Astro.props;

const normalizePath = (path: string) => (path === '/' ? '/' : path.replace(/\/+$/, ''));
const currentPath = normalizePath(Astro.url.pathname);
const desktopRoutes = siteRoutes
  .filter((route) => route.navGroup === 'primary')
  .sort((a, b) => a.order - b.order);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="stylesheet" href="/css/animate.purged.css" />
    <link rel="stylesheet" href="/css/custom-animations.purged.css" />
  </head>
  <body class={bodyClass}>
    <div class="app-shell">
      <div class="desktop-sidebar-spacer d-none d-lg-block" aria-hidden="true"></div>
      <DesktopSidebar currentPath={currentPath} routes={desktopRoutes} socials={socialLinks} sidebarToc={sidebarToc} />
      <div class="app-main">
        <slot />
      </div>
    </div>
  </body>
</html>
