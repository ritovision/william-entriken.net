---
import '@styles/main.scss';
import SiteFooter from '@components/layout/footer/SiteFooter.astro';
import AiAssistModal from '@components/layout/navigation/ai-assist/AiAssistModal.astro';
import DesktopSidebar from '@components/layout/navigation/desktop-sidebar/DesktopSidebar.astro';
import MobileNav from '@components/layout/navigation/mobile-nav/MobileNav.astro';
import { socialLinks } from '@config/social';
import { siteRoutes } from '@config/site';
import type { SidebarTocItem } from '@config/site';
import { SEO_DEFAULTS } from '@shared/constants';
import { buildSchemaGraph, buildSchemaPayload } from '@shared/seo/schema';
import type { SchemaBlock, SeoBlock } from '@shared/types';

interface Props {
  seo?: SeoBlock;
  schema?: SchemaBlock;
  title?: string;
  description?: string;
  bodyClass?: string;
  sidebarToc?: SidebarTocItem[];
  includeAnimateCss?: boolean;
}

const {
  seo,
  schema,
  title,
  description,
  bodyClass = '',
  sidebarToc = [],
  includeAnimateCss = false,
} = Astro.props;

const normalizePath = (path: string) =>
  path === '/' ? '/' : path.replace(/\/+$/, '');
const getNonEmpty = (value?: string) => {
  const trimmed = value?.trim();
  return trimmed ? trimmed : undefined;
};
const isAbsoluteUrl = (value: string) =>
  value.startsWith('http://') || value.startsWith('https://');
const siteBaseUrl = Astro.site ?? new URL(Astro.url.origin);

const currentPath = normalizePath(Astro.url.pathname);
const desktopRoutes = siteRoutes
  .filter((route) => route.navGroup === 'primary')
  .sort((a, b) => a.order - b.order);
const legalRoutes = siteRoutes
  .filter((route) => route.navGroup === 'legal')
  .sort((a, b) => a.order - b.order);
const canonicalTarget = getNonEmpty(seo?.canonicalPath) ?? Astro.url.pathname;
const canonicalHref = isAbsoluteUrl(canonicalTarget)
  ? new URL(canonicalTarget).href
  : new URL(canonicalTarget, siteBaseUrl).href;

const effectiveTitle =
  getNonEmpty(seo?.title) ?? getNonEmpty(title) ?? SEO_DEFAULTS.title;
const effectiveDescription =
  getNonEmpty(seo?.description) ??
  getNonEmpty(description) ??
  SEO_DEFAULTS.description;
const ogTitle = getNonEmpty(seo?.ogTitle) ?? effectiveTitle;
const ogDescription = getNonEmpty(seo?.ogDescription) ?? effectiveDescription;
const ogImageTarget = getNonEmpty(seo?.ogImage) ?? SEO_DEFAULTS.ogImage;
const ogImageHref = isAbsoluteUrl(ogImageTarget)
  ? new URL(ogImageTarget).href
  : new URL(ogImageTarget, siteBaseUrl).href;
const ogImageAlt = `${ogTitle} social preview`;

const schemaGraph = buildSchemaGraph({
  canonicalHref,
  currentPath,
  pageTitle: effectiveTitle,
  pageDescription: effectiveDescription,
  siteBaseUrl,
  routes: siteRoutes,
  schema,
});
const schemaPayload = buildSchemaPayload(schemaGraph);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preload" href="/fonts/Helvetica.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Avenir-Bold.woff2" as="font" type="font/woff2" crossorigin />
    <meta name="robots" content="index, follow" />
    <meta name="description" content={effectiveDescription} />
    <link rel="canonical" href={canonicalHref} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SEO_DEFAULTS.siteName} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:image" content={ogImageHref} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImageHref} />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(schemaPayload)}
    />
    <slot name="head" />
    <title>{effectiveTitle}</title>
    <link rel="icon" type="image/png" href="/images/brand/SEO/favicon.png" />
    <link rel="apple-touch-icon" href="/images/brand/logomark-square.png" />
    {
      includeAnimateCss && (
        <link rel="stylesheet" href="/css/animate.purged.css" />
      )
    }
  </head>
  <body class={bodyClass}>
    <MobileNav
      currentPath={currentPath}
      routes={desktopRoutes}
      socials={socialLinks}
      sidebarToc={sidebarToc}
    />
    <div class="app-shell">
      <div class="desktop-sidebar-spacer d-none d-lg-block" aria-hidden="true">
      </div>
      <DesktopSidebar
        currentPath={currentPath}
        routes={desktopRoutes}
        socials={socialLinks}
        sidebarToc={sidebarToc}
      />
      <div class="app-main">
        <slot />
        <SiteFooter socials={socialLinks} legalLinks={legalRoutes} />
      </div>
    </div>
    <AiAssistModal />
  </body>
</html>
