---
import { Picture as AstroPicture } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import {
  isImageMetadata,
  isOptimizedContentImagePath,
  type ContentImageSource,
} from '@shared/images';
import './image.css';

type ImageImport = Promise<{ default: ImageMetadata }>;
type PictureFormat = 'avif' | 'gif' | 'jpeg' | 'jpg' | 'png' | 'svg' | 'webp';
type ImageFit = 'cover' | 'contain' | 'fill' | 'none' | 'scale-down';

interface Props {
  src: ContentImageSource | ImageImport;
  alt: string;
  class?: string;
  imgClass?: string;
  aspectRatio?: string;
  fit?: ImageFit;
  bg?: string;
  priority?: boolean;
  sizes?: string;
  fallbackLabel?: string;
  formats?: PictureFormat[];
  widths?: number[];
  densities?: number[];
}

const {
  src,
  alt,
  class: wrapperClass = '',
  imgClass = '',
  aspectRatio = '1 / 1',
  fit = 'contain',
  bg = 'transparent',
  priority = false,
  sizes,
  fallbackLabel,
  formats = ['avif', 'webp'],
  widths,
  densities,
} = Astro.props;

const resolvedSrc =
  typeof src === 'string'
    ? src
    : 'then' in src
      ? (await src).default
      : src;

if (
  typeof resolvedSrc === 'string' &&
  isOptimizedContentImagePath(resolvedSrc)
) {
  throw new Error(
    `Picture received unresolved content image path: ${resolvedSrc}. Resolve content image refs before rendering.`,
  );
}

const isDecorative = alt.trim() === '';
const effectiveFallbackLabel = fallbackLabel ?? alt;
const loading = priority ? 'eager' : 'lazy';
const decoding = priority ? 'sync' : 'async';
const fetchPriority = priority ? 'high' : 'auto';
const imageClassName = ['ui-image__img', imgClass].filter(Boolean).join(' ');
const imageKind = isImageMetadata(resolvedSrc) ? 'picture' : 'img';
---

<span
  class:list={['ui-image', wrapperClass]}
  style={`--ui-image-aspect-ratio: ${aspectRatio}; --ui-image-fit: ${fit}; --ui-image-bg: ${bg};`}
  data-ui-image
  data-ui-image-kind={imageKind}
  data-ui-image-decorative={isDecorative ? 'true' : 'false'}
  data-ui-image-fallback-label={effectiveFallbackLabel}
>
  {
    isImageMetadata(resolvedSrc) ? (
      widths !== undefined ? (
        <AstroPicture
          src={resolvedSrc}
          alt={alt}
          class={imageClassName}
          formats={formats}
          width={resolvedSrc.width}
          height={resolvedSrc.height}
          widths={widths}
          loading={loading}
          decoding={decoding}
          fetchpriority={fetchPriority}
          sizes={sizes}
          pictureAttributes={{ class: 'ui-image__picture' }}
        />
      ) : densities !== undefined ? (
        <AstroPicture
          src={resolvedSrc}
          alt={alt}
          class={imageClassName}
          formats={formats}
          width={resolvedSrc.width}
          height={resolvedSrc.height}
          densities={densities}
          loading={loading}
          decoding={decoding}
          fetchpriority={fetchPriority}
          sizes={sizes}
          pictureAttributes={{ class: 'ui-image__picture' }}
        />
      ) : (
        <AstroPicture
          src={resolvedSrc}
          alt={alt}
          class={imageClassName}
          formats={formats}
          width={resolvedSrc.width}
          height={resolvedSrc.height}
          loading={loading}
          decoding={decoding}
          fetchpriority={fetchPriority}
          sizes={sizes}
          pictureAttributes={{ class: 'ui-image__picture' }}
        />
      )
    ) : (
      <img
        src={resolvedSrc}
        alt={alt}
        class={imageClassName}
        loading={loading}
        decoding={decoding}
        fetchpriority={fetchPriority}
        sizes={sizes}
      />
    )
  }
  <span class="ui-image__fallback" data-ui-image-fallback>
    <span class="ui-image__waves" aria-hidden="true"></span>
  </span>
</span>

<script>
  const setFallbackA11y = (
    root: HTMLElement,
    fallback: HTMLElement,
    hasError: boolean,
  ) => {
    const isDecorative = root.dataset.uiImageDecorative === 'true';
    const fallbackLabel = root.dataset.uiImageFallbackLabel ?? '';

    if (!hasError || isDecorative) {
      fallback.setAttribute('aria-hidden', 'true');
      fallback.removeAttribute('role');
      fallback.removeAttribute('aria-label');
      return;
    }

    fallback.setAttribute('aria-hidden', 'false');
    fallback.setAttribute('role', 'img');
    fallback.setAttribute('aria-label', fallbackLabel);
  };

  const setErrorState = (root: HTMLElement, hasError: boolean) => {
    const fallback = root.querySelector<HTMLElement>(
      '[data-ui-image-fallback]',
    );
    if (!fallback) {
      return;
    }

    root.toggleAttribute('data-image-error', hasError);
    setFallbackA11y(root, fallback, hasError);
  };

  const bindImage = (root: HTMLElement) => {
    if (root.dataset.uiImageBound === 'true') {
      return;
    }

    const image = root.querySelector<HTMLImageElement>('img');
    if (!image) {
      return;
    }

    root.dataset.uiImageBound = 'true';
    setErrorState(root, false);

    image.addEventListener('load', () => {
      setErrorState(root, false);
    });

    image.addEventListener('error', () => {
      setErrorState(root, true);
    });

    if (image.complete && image.naturalWidth === 0) {
      setErrorState(root, true);
    }
  };

  const bindAllImages = (container: ParentNode = document) => {
    const roots = Array.from(
      container.querySelectorAll<HTMLElement>('[data-ui-image]'),
    );

    for (const root of roots) {
      bindImage(root);
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => bindAllImages(), {
      once: true,
    });
  } else {
    bindAllImages();
  }

  document.addEventListener('astro:page-load', () => bindAllImages());
</script>
