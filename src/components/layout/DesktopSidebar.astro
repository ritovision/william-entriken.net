---
import type { SocialLink } from '../../config/navigation';
import type { SiteRoute } from '../../config/site';

interface Props {
  currentPath: string;
  routes: SiteRoute[];
  socials: SocialLink[];
}

const { currentPath, routes, socials } = Astro.props;

const normalizePath = (path: string) => (path === '/' ? '/' : path.replace(/\/+$/, ''));
const activePath = normalizePath(currentPath);
---

<aside class="desktop-sidebar d-none d-lg-flex" aria-label="Desktop navigation">
  <div class="desktop-sidebar__inner">
    <div class="desktop-sidebar__logo-wrap">
      <a href="/" class="desktop-sidebar__logo-link" aria-label="Home">
        <img src="/images/brand/wordmark.png" alt="William Entriken wordmark" class="desktop-sidebar__logo" width="200" />
      </a>
    </div>

    <nav class="desktop-sidebar__nav" aria-label="Primary">
      <ul class="desktop-sidebar__nav-list list-unstyled m-0 p-0">
        {routes.map((route) => {
          const isActive = activePath === normalizePath(route.path);

          return (
            <li class="desktop-sidebar__nav-item">
              <a href={route.path} class:list={['desktop-sidebar__nav-link', isActive && 'is-active']}>
                {route.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <div class="desktop-sidebar__social-wrap">
      <div class="desktop-sidebar__social-grid">
        {socials.map((social) => (
          <a
            href={social.href}
            class="desktop-sidebar__social-link"
            target="_blank"
            rel="noreferrer"
            aria-label={social.label}
          >
            <img src={social.iconSrc} alt={`${social.label} icon`} class="desktop-sidebar__social-icon" />
          </a>
        ))}
      </div>
    </div>
  </div>
</aside>
