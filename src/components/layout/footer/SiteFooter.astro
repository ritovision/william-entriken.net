---
import type { SocialLink } from '@config/social';
import type { SiteRoute } from '@config/site';
import Image from '@ui/Image.astro';
import SocialIcon from '@ui/icons/brands/SocialIcon.astro';

interface Props {
  socials: SocialLink[];
  legalLinks: SiteRoute[];
}

const { socials, legalLinks } = Astro.props;
---

<footer class="site-footer" aria-label="Site footer">
  <div class="site-footer__inner container-95">
    <hr class="site-footer__rule" aria-hidden="true" />

    <div class="site-footer__content-row">
      <a href="/" class="site-footer__wordmark-link" aria-label="Home">
        <Image
          src="/images/brand/wordmark.png"
          alt="William Entriken wordmark"
          imgClass="site-footer__wordmark"
          aspectRatio="4 / 1"
        />
      </a>

      <div class="site-footer__social-grid" aria-label="Social media links">
        {
          socials.map((social) => (
            <a
              href={social.href}
              class="site-footer__social-link"
              target="_blank"
              rel="noreferrer"
              aria-label={social.label}
            >
              <SocialIcon id={social.id} class="site-footer__social-icon" />
            </a>
          ))
        }
      </div>

      <nav class="site-footer__legal" aria-label="Legal links">
        {
          legalLinks.map((route) => (
            <a href={route.path} class="site-footer__legal-link">
              {route.label}
            </a>
          ))
        }
      </nav>
    </div>

    <p class="site-footer__copyright m-0">
      <a
        href="https://ritovision.com"
        class="site-footer__credit-link"
        target="_blank"
        rel="noreferrer"
      >
        Designed by RitoVision &copy; 2026
      </a>
    </p>
  </div>
</footer>
