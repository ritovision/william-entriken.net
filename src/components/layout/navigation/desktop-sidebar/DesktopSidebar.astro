---
import type { SocialLink } from '@config/social';
import type { SidebarTocItem, SiteRoute } from '@config/site';
import Image from '@ui/Image.astro';
import SidebarSocialPanel from './SidebarSocialPanel.astro';
import SidebarTabsPanel from './SidebarTabsPanel.astro';

interface Props {
  currentPath: string;
  routes: SiteRoute[];
  socials: SocialLink[];
  sidebarToc: SidebarTocItem[];
}

const { currentPath, routes, socials, sidebarToc } = Astro.props;
---

<aside class="desktop-sidebar d-none d-lg-flex" aria-label="Desktop navigation">
  <div class="desktop-sidebar__inner" data-sidebar-mode="menu">
    <div class="desktop-sidebar__logo-wrap">
      <a href="/" class="desktop-sidebar__logo-link" aria-label="Home">
        <Image
          src="/images/brand/wordmark.png"
          alt="William Entriken wordmark"
          imgClass="desktop-sidebar__logo"
          aspectRatio="4 / 1"
        />
      </a>
    </div>

    <SidebarTabsPanel
      currentPath={currentPath}
      routes={routes}
      sidebarToc={sidebarToc}
    />

    <SidebarSocialPanel socials={socials} />
  </div>
</aside>
