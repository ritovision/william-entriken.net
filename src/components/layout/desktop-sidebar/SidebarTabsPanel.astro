---
import type { SidebarTocItem } from '../../../config/navigation';
import type { SiteRoute } from '../../../config/site';
import InPageSectionsIcon from '../../ui/icons/InPageSectionsIcon.astro';
import MainMenuIcon from '../../ui/icons/MainMenuIcon.astro';
import SidebarMenuPanel from './SidebarMenuPanel.astro';
import SidebarTocPanel from './SidebarTocPanel.astro';

interface Props {
  currentPath: string;
  routes: SiteRoute[];
  sidebarToc: SidebarTocItem[];
}

const { currentPath, routes, sidebarToc } = Astro.props;
const isDev = import.meta.env.DEV;
---

<div class="desktop-sidebar__tabs-region" data-sidebar-tabs data-dev={isDev ? 'true' : 'false'}>
  <h2 class="desktop-sidebar__mode-title m-0" data-tab-title>Main Menu</h2>

  <div class="desktop-sidebar__tabbox" role="tablist" aria-label="Sidebar navigation mode">
    <button
      type="button"
      id="desktop-sidebar-tab-menu"
      class="desktop-sidebar__tab-button is-active"
      role="tab"
      aria-selected="true"
      aria-controls="desktop-sidebar-panel-menu"
      data-tab-target="menu"
    >
      <MainMenuIcon class="desktop-sidebar__tab-icon" />
      <span class="visually-hidden">Main menu</span>
    </button>
    <div class="desktop-sidebar__tab-divider" aria-hidden="true"></div>
    <button
      type="button"
      id="desktop-sidebar-tab-toc"
      class="desktop-sidebar__tab-button"
      role="tab"
      aria-selected="false"
      aria-controls="desktop-sidebar-panel-toc"
      data-tab-target="toc"
    >
      <InPageSectionsIcon class="desktop-sidebar__tab-icon" />
      <span class="visually-hidden">In-page sections</span>
    </button>
  </div>

  <div class="desktop-sidebar__tab-panels">
    <div
      id="desktop-sidebar-panel-menu"
      class="desktop-sidebar__panel is-active"
      role="tabpanel"
      aria-labelledby="desktop-sidebar-tab-menu"
      aria-hidden="false"
      data-tab-panel="menu"
    >
      <SidebarMenuPanel currentPath={currentPath} routes={routes} />
    </div>
    <div
      id="desktop-sidebar-panel-toc"
      class="desktop-sidebar__panel"
      role="tabpanel"
      aria-labelledby="desktop-sidebar-tab-toc"
      aria-hidden="true"
      data-tab-panel="toc"
      hidden
    >
      <SidebarTocPanel toc={sidebarToc} />
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    const roots = document.querySelectorAll('[data-sidebar-tabs]');

    const setupTocActiveTracking = (root) => {
      const tocAnchors = Array.from(root.querySelectorAll('[data-toc-target]'));
      const tocEntries = tocAnchors
        .map((anchor) => {
          const targetId = anchor.getAttribute('data-toc-target');
          if (!targetId) {
            return null;
          }

          const section = document.getElementById(targetId);
          if (!section) {
            return null;
          }

          return { anchor, targetId, section };
        })
        .filter(Boolean);

      if (tocEntries.length === 0) {
        return;
      }

      const markerRatio = 0;
      let activeTargetId = '';
      let rafPending = false;

      const setActiveToc = (targetId) => {
        if (activeTargetId === targetId) {
          return;
        }

        activeTargetId = targetId;
        for (const entry of tocEntries) {
          const isActive = entry.targetId === targetId;
          entry.anchor.classList.toggle('is-active', isActive);
          if (isActive) {
            entry.anchor.setAttribute('aria-current', 'location');
          } else {
            entry.anchor.removeAttribute('aria-current');
          }
        }
      };

      const evaluateActiveToc = () => {
        const markerY = window.innerHeight * markerRatio;
        let crossingEntry = null;
        let firstBelowEntry = null;
        let lastEntry = null;

        for (const entry of tocEntries) {
          const rect = entry.section.getBoundingClientRect();
          lastEntry = entry;

          if (rect.top <= markerY && rect.bottom > markerY) {
            crossingEntry = entry;
            break;
          }

          if (!firstBelowEntry && rect.top > markerY) {
            firstBelowEntry = entry;
          }
        }

        const nextActiveEntry = crossingEntry || firstBelowEntry || lastEntry;
        if (!nextActiveEntry) {
          return;
        }

        setActiveToc(nextActiveEntry.targetId);
      };

      const requestEvaluate = () => {
        if (rafPending) {
          return;
        }

        rafPending = true;
        window.requestAnimationFrame(() => {
          rafPending = false;
          evaluateActiveToc();
        });
      };

      window.addEventListener('scroll', requestEvaluate, { passive: true });
      window.addEventListener('resize', requestEvaluate);

      for (const entry of tocEntries) {
        entry.anchor.addEventListener('click', () => {
          setActiveToc(entry.targetId);
        });
      }

      requestEvaluate();
    };

    const validateToc = (root) => {
      const tocItems = Array.from(root.querySelectorAll('[data-toc-item]'));
      const isDev = root.getAttribute('data-dev') === 'true';

      for (const item of tocItems) {
        const anchor = item.querySelector('[data-toc-target]');
        const targetId = anchor?.getAttribute('data-toc-target');
        if (!targetId) {
          item.remove();
          continue;
        }

        if (!document.getElementById(targetId)) {
          item.remove();
          if (isDev) {
            console.warn(`[DesktopSidebar] TOC target not found: #${targetId}`);
          }
        }
      }

      const tocList = root.querySelector('[data-toc-list]');
      const tocEmpty = root.querySelector('[data-toc-empty]');
      if (tocList && tocEmpty) {
        const remainingItems = tocList.querySelectorAll('[data-toc-item]').length;
        if (remainingItems === 0) {
          tocEmpty.removeAttribute('hidden');
        } else {
          tocEmpty.setAttribute('hidden', '');
        }
      }
    };

    for (const root of roots) {
      const buttons = Array.from(root.querySelectorAll('[data-tab-target]'));
      const panels = Array.from(root.querySelectorAll('[data-tab-panel]'));
      const title = root.querySelector('[data-tab-title]');
      const titleByTarget = {
        menu: 'Main Menu',
        toc: 'In-page Sections',
      };

      const setActiveTab = (target) => {
        if (title) {
          title.textContent = titleByTarget[target] || titleByTarget.menu;
        }

        for (const button of buttons) {
          const isActive = button.getAttribute('data-tab-target') === target;
          button.classList.toggle('is-active', isActive);
          button.setAttribute('aria-selected', String(isActive));
          button.tabIndex = isActive ? 0 : -1;
        }

        for (const panel of panels) {
          const isActive = panel.getAttribute('data-tab-panel') === target;
          panel.classList.toggle('is-active', isActive);
          panel.setAttribute('aria-hidden', String(!isActive));
          if (isActive) {
            panel.removeAttribute('hidden');
          } else {
            panel.setAttribute('hidden', '');
          }
        }
      };

      for (const button of buttons) {
        button.addEventListener('click', () => {
          const target = button.getAttribute('data-tab-target');
          if (target) {
            setActiveTab(target);
          }
        });

        button.addEventListener('keydown', (event) => {
          const key = event.key;
          if (!['ArrowLeft', 'ArrowRight', 'Home', 'End'].includes(key)) {
            return;
          }

          event.preventDefault();

          const currentIndex = buttons.indexOf(button);
          if (currentIndex < 0) {
            return;
          }

          let nextIndex = currentIndex;
          if (key === 'ArrowLeft') {
            nextIndex = (currentIndex - 1 + buttons.length) % buttons.length;
          } else if (key === 'ArrowRight') {
            nextIndex = (currentIndex + 1) % buttons.length;
          } else if (key === 'Home') {
            nextIndex = 0;
          } else if (key === 'End') {
            nextIndex = buttons.length - 1;
          }

          const nextButton = buttons[nextIndex];
          if (!nextButton) {
            return;
          }

          nextButton.focus();
          const target = nextButton.getAttribute('data-tab-target');
          if (target) {
            setActiveTab(target);
          }
        });
      }

      setActiveTab('menu');

      const initToc = () => {
        validateToc(root);
        setupTocActiveTracking(root);
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initToc, { once: true });
      } else {
        initToc();
      }
    }
  })();
</script>
