---
import Image from "@ui/Image.astro";

interface RitoProfile {
  name: string;
  alternateName: string[];
  role: string;
  description: string;
  url: string;
  image: string;
  sameAs: string[];
  worksFor: {
    name: string;
    url: string;
  };
  statusNote: string;
}

interface Props {
  profile: RitoProfile;
}

const { profile } = Astro.props;
---

<section
  id="rito-profile"
  class="container-95 section-stack bg-content-dark border-gold"
  aria-label="Rito profile placeholder"
  style="margin-top: 2rem; margin-bottom: 3rem;"
>
  <h1 class="text-gold text-center m-0">{profile.name}</h1>
  <p class="text-white text-center m-0">{profile.role}</p>

  <div class="rito-profile__media">
    <Image
      src={profile.image}
      alt={`${profile.name} profile portrait`}
      class="rito-profile__image-wrap"
      imgClass="rito-profile__image"
      aspectRatio="4 / 5"
      fit="cover"
      priority={true}
    />
  </div>

  <p class="text-white m-0">{profile.description}</p>
  <p class="text-gold m-0">{profile.statusNote}</p>

  <p class="m-0">
    <strong class="text-gold">Also Known As:</strong>
    <span class="text-white"> {profile.alternateName.join(", ")}</span>
  </p>
  <p class="m-0">
    <strong class="text-gold">Organization:</strong>
    <a href={profile.worksFor.url} class="text-white" target="_blank" rel="noreferrer">
      {profile.worksFor.name}
    </a>
  </p>
  <p class="m-0">
    <strong class="text-gold">Website:</strong>
    <a href={profile.url} class="text-white" target="_blank" rel="noreferrer">
      {profile.url}
    </a>
  </p>

  <div>
    <h2 class="text-gold text-center m-0">Profiles</h2>
    <ul class="list-unstyled m-0 p-0 d-grid gap-2">
      {
        profile.sameAs.map((link) => (
          <li>
            <a href={link} class="text-white" target="_blank" rel="noreferrer">
              {link}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .rito-profile__media {
    width: min(100%, 360px);
    margin: 0 auto;
  }

  .rito-profile__image-wrap {
    width: 100%;
  }

  .rito-profile__image {
    border: 1px solid var(--color-accent);
  }
</style>
