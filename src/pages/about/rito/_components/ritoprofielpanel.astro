---
import BrandGithubIcon from '@ui/icons/brands/BrandGithubIcon.astro';
import BrandInstagramIcon from '@ui/icons/brands/BrandInstagramIcon.astro';
import BrandLinkedinIcon from '@ui/icons/brands/BrandLinkedinIcon.astro';
import BrandXIcon from '@ui/icons/brands/BrandXIcon.astro';
import Image from '@ui/Image.astro';
import './rito-profile-panel.css';

interface SelectedLink {
  label: string;
  href: string;
}

interface RitoProfile {
  name: string;
  alternateName: string[];
  role: string;
  summary: string;
  summaryParagraphs?: string[];
  url: string;
  image: string;
  sameAs: string[];
  worksFor: {
    name: string;
    url: string;
  };
  wordmarkLink: {
    href: string;
    src: string;
    alt: string;
  };
  socialLinks: {
    linkedin: string;
    x: string;
    instagram: string;
    github: string;
  };
  selectedLinksTitle: string;
  selectedLinks: SelectedLink[];
}

interface Props {
  profile: RitoProfile;
}

const { profile } = Astro.props;
---

<section
  id="rito-profile"
  class="rito-profile-panel container-95 bg-primary-navy"
  aria-label={`${profile.name} profile`}
>
  <div class="rito-profile-panel__identity">
    <div class="rito-profile-panel__media">
      <Image
        src={profile.image}
        alt={`${profile.name} profile portrait`}
        class="rito-profile-panel__image-wrap"
        imgClass="rito-profile-panel__image"
        aspectRatio="1 / 1"
        fit="contain"
        bg="var(--color-primary)"
        priority={true}
      />

      <div class="rito-profile-panel__socials" aria-label="Rito social links">
        <a
          href={profile.socialLinks.linkedin}
          class="rito-profile-panel__social-link"
          target="_blank"
          rel="noreferrer"
          aria-label="Rito on LinkedIn"
        >
          <BrandLinkedinIcon class="rito-profile-panel__social-icon" />
        </a>
        <a
          href={profile.socialLinks.x}
          class="rito-profile-panel__social-link"
          target="_blank"
          rel="noreferrer"
          aria-label="Rito on X"
        >
          <BrandXIcon class="rito-profile-panel__social-icon" />
        </a>
        <a
          href={profile.socialLinks.instagram}
          class="rito-profile-panel__social-link"
          target="_blank"
          rel="noreferrer"
          aria-label="Rito on Instagram"
        >
          <BrandInstagramIcon class="rito-profile-panel__social-icon" />
        </a>
        <a
          href={profile.socialLinks.github}
          class="rito-profile-panel__social-link"
          target="_blank"
          rel="noreferrer"
          aria-label="Rito on GitHub"
        >
          <BrandGithubIcon class="rito-profile-panel__social-icon" />
        </a>
      </div>
    </div>

    <div class="rito-profile-panel__intro">
      <h1 class="rito-profile-panel__name m-0">{profile.name}</h1>
      <h2 class="rito-profile-panel__role m-0">{profile.role}</h2>
      <div class="rito-profile-panel__summary-stack">
        <p class="rito-profile-panel__summary text-white m-0">
          {profile.summary}
        </p>
        {
          (profile.summaryParagraphs ?? []).map((paragraph) => (
            <p class="rito-profile-panel__summary text-white m-0">
              {paragraph}
            </p>
          ))
        }
      </div>

      <a
        href={profile.wordmarkLink.href}
        class="rito-profile-panel__wordmark-link"
        target="_blank"
        rel="noreferrer"
      >
        <Image
          src={profile.wordmarkLink.src}
          alt={profile.wordmarkLink.alt}
          class="rito-profile-panel__wordmark-wrap"
          imgClass="rito-profile-panel__wordmark-image"
          aspectRatio="4 / 1"
          fit="contain"
          bg="var(--color-primary)"
        />
      </a>

      <dl class="rito-profile-panel__facts m-0">
        <div class="rito-profile-panel__fact-item">
          <dt class="rito-profile-panel__fact-label">Also Known As</dt>
          <dd class="rito-profile-panel__fact-value m-0">
            {profile.alternateName.join(', ')}
          </dd>
        </div>
        <div class="rito-profile-panel__fact-item">
          <dt class="rito-profile-panel__fact-label">Works For</dt>
          <dd class="rito-profile-panel__fact-value m-0">
            <a
              href={profile.worksFor.url}
              class="text-white"
              target="_blank"
              rel="noreferrer"
            >
              {profile.worksFor.name}
            </a>
          </dd>
        </div>
        <div class="rito-profile-panel__fact-item">
          <dt class="rito-profile-panel__fact-label">Website</dt>
          <dd class="rito-profile-panel__fact-value m-0">
            <a
              href={profile.url}
              class="text-white"
              target="_blank"
              rel="noreferrer"
            >
              {profile.url}
            </a>
          </dd>
        </div>
      </dl>
    </div>
  </div>

  <div class="rito-profile-panel__section">
    <h2 class="rito-profile-panel__section-title m-0">
      {profile.selectedLinksTitle}
    </h2>
    <ul class="rito-profile-panel__links list-unstyled m-0 p-0">
      {
        profile.selectedLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-white"
              target="_blank"
              rel="noreferrer"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
