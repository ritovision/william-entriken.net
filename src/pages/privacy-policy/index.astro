---
import BaseLayout from '@layouts/BaseLayout.astro';
import content from './_content.json';
import './style.css';

interface PrivacySection {
  id: string;
  title: string;
  paragraphs: string[];
  email?: string;
}

const { seo, title, lastUpdated } = content;
const sections = content.sections as PrivacySection[];
const sidebarToc = sections.map((section) => ({
  label: section.title,
  targetId: section.id,
}));
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  sidebarToc={sidebarToc}
>
  <main class="privacy-page page-placeholder">
    <article class="privacy-page__inner container-95 border-white">
      <header class="privacy-page__header">
        <h1 class="privacy-page__title text-gold m-0">{title}</h1>
        <p class="privacy-page__updated m-0 text-white">
          Last updated: {lastUpdated}
        </p>
      </header>

      <div class="privacy-page__sections">
        {
          sections.map((section) => (
            <section
              id={section.id}
              class="privacy-page__section section-stack"
            >
              <h2 class="privacy-page__section-title text-gold m-0">
                {section.title}
              </h2>
              {section.paragraphs.map((paragraph) => (
                <p class="privacy-page__paragraph text-white m-0">
                  {paragraph}
                </p>
              ))}
              {section.email && (
                <p class="privacy-page__paragraph m-0">
                  <a
                    href={`mailto:${section.email}`}
                    class="privacy-page__email-link"
                  >
                    {section.email}
                  </a>
                </p>
              )}
            </section>
          ))
        }
      </div>
    </article>
  </main>
</BaseLayout>
