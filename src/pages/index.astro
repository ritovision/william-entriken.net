---
import BaseLayout from '@layouts/BaseLayout.astro';
import ArtworkRevolutionSection from '@sections/ArtworkRevolutionSection.astro';
import GenesisPaperSection from '@sections/GenesisPaperSection.astro';
import IcoAdvisorySection from '@sections/IcoAdvisorySection.astro';
import LegacyInfluenceSection from '@sections/LegacyInfluenceSection.astro';
import OtherNotableImpactsSection from '@sections/OtherNotableImpactsSection.astro';
import type { SchemaBlock } from '@shared/types';
import ImageTileGridSection from '@sections/ImageTileGridSection.astro';
import PlatformsShowcaseSection from '@sections/PlatformsShowcaseSection.astro';
import PublicSpeakingSection from '@sections/PublicSpeakingSection.astro';
import content from './_content.json';
import schemaContent from './_schema.json';

interface ImageTileGridItem {
  src: string;
  alt: string;
}

interface HomePageContent {
  seo: {
    title: string;
    description: string;
  };
  legacyInfluence: {
    id: string;
    title: string;
    switchLabel: string;
    conciseLabel: string;
    detailedLabel: string;
    concise: string;
    detailed: string[];
  };
  otherNotableImpacts: {
    id: string;
    title: string;
    bottomImage: {
      src: string;
      alt: string;
    };
    panels: Array<{
      id: 'dapp-fintech' | 'civic-hacker';
      label: string;
      paragraphs: string[];
      buttons?: Array<{
        label: string;
        href: string;
      }>;
    }>;
  };
  artworkRevolution: {
    id: string;
    title: string;
    quote: {
      text: string;
      attribution: string;
    };
    body: string[];
    closingQuote: {
      text: string;
      attribution: string;
    };
  };
  media: {
    id: string;
    title: string;
    subtitle?: string;
    body?: string;
    expandLabel: string;
    collapsedRows: {
      mobile: number;
      tablet: number;
      desktop: number;
    };
    columns: {
      mobile: number;
      tablet: number;
      desktop: number;
    };
    items: ImageTileGridItem[];
  };
  bigTechAdoption: {
    id: string;
    title: string;
    subtitle?: string;
    body: string;
    expandLabel: string;
    collapsedRows: {
      mobile: number;
      tablet: number;
      desktop: number;
    };
    columns: {
      mobile: number;
      tablet: number;
      desktop: number;
    };
    items: ImageTileGridItem[];
  };
  celebrityEmbrace: {
    id: string;
    title: string;
    subtitle?: string;
    body: string;
    expandLabel: string;
    collapsedRows: {
      mobile: number;
      tablet: number;
      desktop: number;
    };
    columns: {
      mobile: number;
      tablet: number;
      desktop: number;
    };
    items: ImageTileGridItem[];
  };
  icoAdvisory: {
    id: string;
    tocLabel: string;
    portrait: {
      src: string;
      alt: string;
    };
    coinsImage: {
      src: string;
      alt: string;
    };
    message: {
      lead: string;
      emphasis: string;
      tail: string;
      note: string;
    };
    cta: {
      label: string;
      href: string;
    };
  };
  scholarlyInfluence: {
    id: string;
    title: string;
    subtitle: string;
    body: string;
    expandLabel: string;
    collapsedRows: {
      mobile: number;
      tablet: number;
      desktop: number;
    };
    columns: {
      mobile: number;
      tablet: number;
      desktop: number;
    };
    items: ImageTileGridItem[];
  };
  investorBacking: {
    id: string;
    title: string;
    subtitle?: string;
    body: string;
    expandLabel: string;
    collapsedRows: {
      mobile: number;
      tablet: number;
      desktop: number;
    };
    columns: {
      mobile: number;
      tablet: number;
      desktop: number;
    };
    items: ImageTileGridItem[];
  };
  platforms: {
    id: string;
    title: string;
    body: string;
    backgroundImage: {
      src: string;
      alt: string;
    };
    gallery: {
      ariaLabel: string;
      expandLabel: string;
      collapsedRows: {
        mobile: number;
        tablet: number;
        desktop: number;
      };
      columns: {
        mobile: number;
        tablet: number;
        desktop: number;
      };
      items: ImageTileGridItem[];
    };
  };
  publicSpeaking: {
    id: string;
    title: string;
    intro: string;
    ctaLead: string;
    cta: {
      label: string;
      href: string;
    };
    features: Array<{
      title: string;
      body: string;
      image: {
        src: string;
        alt: string;
      };
      imageSide: 'left' | 'right';
      tone: 'dark' | 'light';
    }>;
  };
  genesisPaper: {
    id: string;
    title: string;
    body: string;
    paperHref: string;
    image: {
      src: string;
      alt: string;
    };
  };
}

const {
  seo,
  legacyInfluence,
  otherNotableImpacts,
  artworkRevolution,
  media,
  bigTechAdoption,
  celebrityEmbrace,
  icoAdvisory,
  scholarlyInfluence,
  investorBacking,
  platforms,
  publicSpeaking,
  genesisPaper,
} = content as HomePageContent;
const schema = schemaContent as SchemaBlock;
const sidebarToc = [
  {
    label: 'Legacy Introduction',
    targetId: legacyInfluence.id,
  },
  {
    label: otherNotableImpacts.title,
    targetId: otherNotableImpacts.id,
  },
  {
    label: genesisPaper.title,
    targetId: genesisPaper.id,
  },
  {
    label: 'News Outlets',
    targetId: media.id,
  },
  {
    label: bigTechAdoption.title,
    targetId: bigTechAdoption.id,
  },
  {
    label: celebrityEmbrace.title,
    targetId: celebrityEmbrace.id,
  },
  {
    label: artworkRevolution.title,
    targetId: artworkRevolution.id,
  },
  {
    label: scholarlyInfluence.title,
    targetId: scholarlyInfluence.id,
  },
  {
    label: investorBacking.title,
    targetId: investorBacking.id,
  },
  {
    label: icoAdvisory.tocLabel,
    targetId: icoAdvisory.id,
  },
  {
    label: platforms.title,
    targetId: platforms.id,
  },
  {
    label: publicSpeaking.title,
    targetId: publicSpeaking.id,
  },
];
---

<BaseLayout seo={seo} schema={schema} sidebarToc={sidebarToc}>
  <main class="page-main home-page">
    <h1 class="visually-hidden">William Entriken</h1>
    <LegacyInfluenceSection {...legacyInfluence} />
    <OtherNotableImpactsSection {...otherNotableImpacts} />
    <GenesisPaperSection {...genesisPaper} />
    <ImageTileGridSection {...media} />
    <ImageTileGridSection {...bigTechAdoption} />
    <ImageTileGridSection {...celebrityEmbrace} />
    <ArtworkRevolutionSection {...artworkRevolution} />
    <ImageTileGridSection {...scholarlyInfluence} />
    <ImageTileGridSection {...investorBacking} />
    <IcoAdvisorySection {...icoAdvisory} />
    <PlatformsShowcaseSection {...platforms} />
    <PublicSpeakingSection {...publicSpeaking} />
  </main>
</BaseLayout>
