---
import BaseLayout from '@layouts/BaseLayout.astro';
import type { SchemaBlock } from '@shared/types';
import ImageTileGridSection from '@sections/ImageTileGridSection.astro';
import PlatformsShowcaseSection from '@sections/PlatformsShowcaseSection.astro';
import content from './_content.json';
import schemaContent from './_schema.json';

interface ImageTileGridItem {
  src: string;
  alt: string;
}

interface HomePageContent {
  seo: {
    title: string;
    description: string;
  };
  media: {
    id: string;
    title: string;
    subtitle?: string;
    body?: string;
    expandLabel: string;
    collapsedRows: {
      mobile: number;
      tablet: number;
      desktop: number;
    };
    columns: {
      mobile: number;
      tablet: number;
      desktop: number;
    };
    items: ImageTileGridItem[];
  };
  bigTechAdoption: {
    id: string;
    title: string;
    subtitle?: string;
    body: string;
    expandLabel: string;
    collapsedRows: {
      mobile: number;
      tablet: number;
      desktop: number;
    };
    columns: {
      mobile: number;
      tablet: number;
      desktop: number;
    };
    items: ImageTileGridItem[];
  };
  celebrityEmbrace: {
    id: string;
    title: string;
    subtitle?: string;
    body: string;
    expandLabel: string;
    collapsedRows: {
      mobile: number;
      tablet: number;
      desktop: number;
    };
    columns: {
      mobile: number;
      tablet: number;
      desktop: number;
    };
    items: ImageTileGridItem[];
  };
  scholarlyInfluence: {
    id: string;
    title: string;
    subtitle: string;
    body: string;
    expandLabel: string;
    collapsedRows: {
      mobile: number;
      tablet: number;
      desktop: number;
    };
    columns: {
      mobile: number;
      tablet: number;
      desktop: number;
    };
    items: ImageTileGridItem[];
  };
  investorBacking: {
    id: string;
    title: string;
    subtitle?: string;
    body: string;
    expandLabel: string;
    collapsedRows: {
      mobile: number;
      tablet: number;
      desktop: number;
    };
    columns: {
      mobile: number;
      tablet: number;
      desktop: number;
    };
    items: ImageTileGridItem[];
  };
  platforms: {
    id: string;
    title: string;
    body: string;
    backgroundImage: {
      src: string;
      alt: string;
    };
    gallery: {
      ariaLabel: string;
      expandLabel: string;
      collapsedRows: {
        mobile: number;
        tablet: number;
        desktop: number;
      };
      columns: {
        mobile: number;
        tablet: number;
        desktop: number;
      };
      items: ImageTileGridItem[];
    };
  };
}

const {
  seo,
  media,
  bigTechAdoption,
  celebrityEmbrace,
  scholarlyInfluence,
  investorBacking,
  platforms,
} = content as HomePageContent;
const schema = schemaContent as SchemaBlock;
const sidebarToc = [
  {
    label: 'News Outlets',
    targetId: media.id,
  },
  {
    label: bigTechAdoption.title,
    targetId: bigTechAdoption.id,
  },
  {
    label: celebrityEmbrace.title,
    targetId: celebrityEmbrace.id,
  },
  {
    label: scholarlyInfluence.title,
    targetId: scholarlyInfluence.id,
  },
  {
    label: investorBacking.title,
    targetId: investorBacking.id,
  },
  {
    label: platforms.title,
    targetId: platforms.id,
  },
];
---

<BaseLayout seo={seo} schema={schema} sidebarToc={sidebarToc}>
  <main class="page-main home-page">
    <h1 class="visually-hidden">William Entriken</h1>
    <ImageTileGridSection {...media} />
    <ImageTileGridSection {...bigTechAdoption} />
    <ImageTileGridSection {...celebrityEmbrace} />
    <ImageTileGridSection {...scholarlyInfluence} />
    <ImageTileGridSection {...investorBacking} />
    <PlatformsShowcaseSection {...platforms} />
  </main>
</BaseLayout>
