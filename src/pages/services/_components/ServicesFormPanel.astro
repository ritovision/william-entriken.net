---
import FormResultModal from '@sections/FormResultModal.astro';

interface ServicesFormSection {
  id: string;
  title: string;
  submitLabel: string;
}

interface Props {
  section: ServicesFormSection;
}

const { section } = Astro.props;
---

<section
  id={section.id}
  class="forms-panel container-95 section-stack"
  aria-label={`${section.title} section`}
>
  <h2 class="forms-panel__title text-gold text-center m-0">{section.title}</h2>
  <p class="text-white text-center fst-italic mb-0">
    (Required before purchasing retainer plans above)
  </p>

  <form
    id="services-form"
    class="site-form"
    data-form-kind="services"
    novalidate
  >
    <input type="hidden" name="formType" value="services" />

    <div class="site-form__grid">
      <input name="firstName" type="text" placeholder="First Name *" required />
      <input name="lastName" type="text" placeholder="Last Name" />

      <input name="email" type="email" placeholder="Email *" required />
      <input name="phone" type="tel" placeholder="Phone" />

      <input name="companyName" type="text" placeholder="Company Name" />
      <input name="position" type="text" placeholder="Position" />

      <input
        class="site-form__full"
        name="projectWebsite"
        type="text"
        placeholder="Project / Company Website"
      />

      <select class="site-form__full" name="industry" required>
        <option value="" disabled selected>What Industry Are You In? *</option>
        <option>Technology</option>
        <option>Finance</option>
        <option>Healthcare</option>
        <option>Education</option>
        <option>Web3</option>
        <option>Gaming</option>
        <option>Retail</option>
        <option>IT</option>
        <option>Other</option>
      </select>

      <select class="site-form__full" name="duration" required>
        <option value="" disabled selected>Duration of Engagement Sought *</option>
        <option>1 Month</option>
        <option>1–3 Months</option>
        <option>3–6 Months</option>
        <option>Long-term</option>
      </select>

      <select class="site-form__full" name="assistanceTime" required>
        <option value="" disabled selected>
          How Soon Do You Require Assistance? *
        </option>
        <option>ASAP</option>
        <option>Within 1 week</option>
        <option>Within 1 month</option>
        <option>Flexible</option>
      </select>

      <select class="site-form__full" name="orgSize" required>
        <option value="" disabled selected>Organization Size *</option>
        <option>1–10</option>
        <option>11–50</option>
        <option>51–200</option>
        <option>201–500</option>
        <option>500+</option>
      </select>

      <textarea
        class="site-form__full"
        name="details"
        rows="4"
        placeholder="Please Detail Your Needs and Questions *"
        required></textarea>

      <button
        type="submit"
        class="btn btn-brand-gold-pill site-form__submit site-form__full"
      >
        {section.submitLabel}
      </button>

    </div>
  </form>

  <FormResultModal idPrefix="services" />
</section>

<script>
  import { initFormRuntime } from '@sections/scripts/formRuntime';

  initFormRuntime();
</script>
