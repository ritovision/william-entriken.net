---
import BaseLayout from "@layouts/BaseLayout.astro";
import type { SchemaBlock } from "@shared/types";
import ServicesFormPanel from "./_components/ServicesFormPanel.astro";
import content from "./_content.json";
import schemaContent from "./_schema.json";

interface ServicesPageContent {
  seo: {
    title: string;
    description: string;
  };
  formSection: {
    id: string;
    title: string;
    submitLabel: string;
  };
}

const { seo, formSection } = content as ServicesPageContent;
const schema = schemaContent as SchemaBlock;
const sidebarToc = [
  {
    label: formSection.title,
    targetId: formSection.id,
  },
];
---

<BaseLayout seo={seo} schema={schema} sidebarToc={sidebarToc}>
  <main class="page-placeholder">
    <ServicesFormPanel section={formSection} />
  </main>
</BaseLayout>
