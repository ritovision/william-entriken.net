---
import PressCoverageFeed from '@shared/feeds/press/PressCoverageFeed.astro';
import pressCoverage from '../../../data/feeds/press-coverage.json';
---

<section
  id="press-list"
  class="container-95 section-stack"
  style="margin-top: var(--space-section-xl); margin-bottom: var(--space-section-xl);"
  aria-label="Press coverage section"
>
  <h2 class="text-gold text-center m-0">Press List</h2>
  <PressCoverageFeed items={pressCoverage} />
</section>
