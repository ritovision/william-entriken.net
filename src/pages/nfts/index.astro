---
import BaseLayout from '@layouts/BaseLayout.astro';
import { resolveContentImageRefs, resolveSchemaImageRefs } from '@shared/images';
import type { SchemaBlock } from '@shared/types';
import NftsImageStack from './_components/NftsImageStack.astro';
import NftMarketplacesPanel from './_components/NftMarketplacesPanel.astro';
import SuSquaresPanel from './_components/SuSquaresPanel.astro';
import content from './_content.json';
import schemaContent from './_schema.json';

interface NftsImage {
  src: string;
  alt: string;
}

interface NftsHeroSection {
  id: string;
  title: string;
  images: {
    left: NftsImage;
    right: NftsImage;
  };
}

interface NftsPageContent {
  seo: {
    title: string;
    description: string;
  };
  heroSection: NftsHeroSection;
  suSquaresSection: {
    id: string;
    title: string;
    subtitle: string;
    introParagraphs: string[];
    billboardLead: string;
    iframe: {
      title: string;
      src: string;
    };
    billboardNote: string;
    closingParagraph: string;
    featuredImagesSection: {
      id: string;
      title: string;
    };
    featuredImages: {
      src: string;
      alt: string;
      aspectRatio: string;
    }[];
    sections: {
      id: string;
      heading: string;
      paragraphs?: string[];
      items?: {
        label: string;
        text: string;
      }[];
    }[];
  };
  marketplacesSection: {
    id: string;
    title: string;
    items: {
      name: string;
      href: string;
      image: {
        src: string;
        alt: string;
      };
    }[];
  };
}

const { seo, heroSection, suSquaresSection, marketplacesSection } =
  resolveContentImageRefs(content as NftsPageContent);
const schema = resolveSchemaImageRefs(
  schemaContent as SchemaBlock,
  Astro.site ?? new URL(Astro.url.origin),
);
const sidebarToc = [
  {
    label: heroSection.title,
    targetId: heroSection.id,
  },
  {
    label: suSquaresSection.subtitle,
    targetId: `${suSquaresSection.id}-subtitle`,
  },
  ...suSquaresSection.sections.map((section) => ({
    label: section.heading,
    targetId: section.id,
  })),
  {
    label: suSquaresSection.featuredImagesSection.title,
    targetId: suSquaresSection.featuredImagesSection.id,
  },
  {
    label: 'NFT Marketplaces',
    targetId: marketplacesSection.id,
  },
];
---

<BaseLayout seo={seo} schema={schema} sidebarToc={sidebarToc}>
  <main class="page-main">
    <NftsImageStack section={heroSection} />
    <SuSquaresPanel section={suSquaresSection} />
    <NftMarketplacesPanel section={marketplacesSection} />
  </main>
</BaseLayout>
