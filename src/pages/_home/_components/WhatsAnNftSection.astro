---
import Picture from '@ui/Picture.astro';
import '../_styles/whats-an-nft-section.css';

interface WhatsAnNftSectionContent {
  id: string;
  tocLabel: string;
  eyebrow: string;
  title: string;
  image: {
    src: string;
    alt: string;
  };
  overlayText: string;
}

const { id, title, tocLabel, eyebrow, image, overlayText } =
  Astro.props as WhatsAnNftSectionContent;
---

<section
  id={id}
  class="whats-an-nft container-95 section-stack"
  aria-label={tocLabel}
>
  <div class="whats-an-nft__panel whats-an-nft__panel--copy">
    <p class="whats-an-nft__eyebrow text-white">{eyebrow}</p>
    <h2 class="whats-an-nft__title text-gold">{title}</h2>
  </div>

  <div class="whats-an-nft__panel whats-an-nft__panel--image">
    <Picture
      src={image.src}
      alt={image.alt}
      class="whats-an-nft__image-tag"
      imgClass="whats-an-nft__image-tag-img"
      aspectRatio="1 / 1"
      fit="cover"
    />
    <p class="whats-an-nft__overlay text-white">{overlayText}</p>
  </div>
</section>
