    "swiper": "^12.1.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/react": "^4.4.2",
    "@fullhuman/postcss-purgecss": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "purgecss": "^8.0.0",
    "sass": "^1.97.3",
    "typescript": "^5.9.3"
